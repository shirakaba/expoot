{
  "name": "expo-desktop",
  "version": "0.1.28",
  "description": "Best-effort desktop support for Expo",
  "keywords": [
    "android",
    "expo",
    "ios",
    "macos",
    "react native",
    "react native desktop",
    "windows"
  ],
  "homepage": "https://github.com/shirakaba/expo-desktop/tree/main/packages/expo-desktop",
  "bugs": {
    "url": "https://github.com/shirakaba/expo-desktop/issues"
  },
  "license": "MIT",
  "author": "Jamie Birch <14055146+shirakaba@users.noreply.github.com> (https://github.com/shirakaba)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shirakaba/expo-desktop.git",
    "directory": "packages/expo-desktop"
  },
  "bin": {
    "expo-desktop": "build/cli.js"
  },
  "files": [
    "build"
  ],
  "type": "module",
  "exports": {
    ".": "./build/cli.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "generate-config": "node scripts/generate-config.ts",
    "schema": "node scripts/update-schema.ts",
    "start": "node src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "arktype": "^2.2.0",
    "citty": "^0.2.2",
    "expo-desktop-config-plugins": "workspace:^1.1.25",
    "expo-desktop-prebuild-config": "workspace:^1.0.12",
    "glob": "^10.5.0",
    "kleur": "^4.1.5",
    "mustache": "^4.2.0",
    "shescape": "^2.1.12",
    "toml": "^4.1.1"
  },
  "devDependencies": {
    "@expo/config": "catalog:react-native-81",
    "@expo/config-plugins": "catalog:react-native-81",
    "@tsconfig/node24": "catalog:base",
    "@types/mustache": "^4.2.6",
    "@types/node": "catalog:base",
    "@typescript/native-preview": "catalog:base",
    "vitest": "catalog:base"
  },
  "peerDependencies": {
    "@expo/config": ">=12.0.0",
    "@expo/config-plugins": ">=54.0.0"
  },
  "lint-staged": {
    "scripts/update-schema.ts": [
      "node --run schema",
      "oxfmt"
    ],
    "src/app-config.ts": [
      "node --run schema",
      "oxfmt"
    ]
  }
}
