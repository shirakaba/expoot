{
  "name": "expo-desktop-config-plugins",
  "version": "1.1.29",
  "description": "Desktop-friendly Expo config plugins",
  "keywords": [
    "android",
    "expo",
    "ios",
    "macos",
    "react native",
    "react native desktop",
    "windows"
  ],
  "homepage": "https://github.com/shirakaba/expo-desktop/tree/main/packages/expo-desktop-config-plugins",
  "bugs": {
    "url": "https://github.com/shirakaba/expo-desktop/issues"
  },
  "license": "MIT",
  "author": "Jamie Birch <14055146+shirakaba@users.noreply.github.com> (https://github.com/shirakaba)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shirakaba/expo-desktop.git",
    "directory": "packages/expo-desktop-config-plugins"
  },
  "files": [
    "app.plugin.js",
    "LICENCE-expo.txt",
    "src",
    "types"
  ],
  "type": "commonjs",
  "exports": {
    "./app.plugin": "./app.plugin.js",
    "./app.plugin.js": "./app.plugin.js",
    ".": {
      "types": "./types/src/index.d.ts",
      "require": "./src/index.js"
    },
    "./plugins": "./src/plugins/index.js",
    "./plugins/android": "./src/plugins/android/index.js",
    "./plugins/android/*": "./src/plugins/android/*.js",
    "./plugins/ios": "./src/plugins/ios/index.js",
    "./plugins/ios/*": "./src/plugins/ios/*.js",
    "./plugins/macos": "./src/plugins/macos/index.js",
    "./plugins/macos/*": "./src/plugins/macos/*.js",
    "./plugins/mod-compiler": "./src/plugins/mod-compiler.js",
    "./plugins/with-expo-desktop": "./src/plugins/with-expo-desktop.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsgo --declaration --emitDeclarationOnly --allowJs --outDir types"
  },
  "dependencies": {
    "@expo/json-file": "^10.0.13",
    "@expo/plist": "^0.4.8",
    "chalk": "^4.1.2",
    "debug": "^4.3.4",
    "fast-xml-builder": "^1.2.0",
    "fast-xml-parser": "^5.8.0",
    "glob": "^10.5.0",
    "slash": "^3.0.0",
    "slugify": "^1.6.6",
    "xcode": "^3.0.1"
  },
  "devDependencies": {
    "@expo/config-plugins": "catalog:react-native-81",
    "@expo/config-types": "catalog:react-native-81",
    "@tsconfig/node24": "catalog:base",
    "@types/debug": "^4.1.7",
    "@types/node": "catalog:base",
    "@typescript/native-preview": "catalog:base"
  },
  "peerDependencies": {
    "@expo/config-plugins": ">=54.0.0",
    "@expo/config-types": ">=54.0.0"
  }
}
