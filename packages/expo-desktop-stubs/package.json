{
  "name": "expo-desktop-stubs",
  "version": "1.0.0",
  "description": "Stubs for supporting Expo on Expo Desktop",
  "keywords": [
    "android",
    "expo",
    "ios",
    "macos",
    "react native",
    "react native desktop",
    "windows"
  ],
  "homepage": "https://github.com/shirakaba/expo-desktop/tree/main/packages/expo-desktop-stubs",
  "bugs": {
    "url": "https://github.com/shirakaba/expo-desktop/issues"
  },
  "license": "MIT",
  "author": "Jamie Birch <14055146+shirakaba@users.noreply.github.com> (https://github.com/shirakaba)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shirakaba/expo-desktop.git",
    "directory": "packages/expo-desktop-stubs"
  },
  "files": [
    "LICENCE-expo.txt",
    "src"
  ],
  "type": "module",
  "react-native": "src/index.ts",
  "scripts": {
    "codegen:windows": "react-native codegen-windows"
  },
  "devDependencies": {
    "expo-desktop-modules-core-54": "workspace:",
    "react-native": "catalog:react-native-81",
    "react-native-windows": "catalog:react-native-81"
  },
  "peerDependencies": {
    "expo-desktop-modules-core-54": "*",
    "react-native": "*",
    "react-native-windows": "*"
  },
  "codegenConfig": {
    "name": "ExpoDesktopStubsSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "includesGeneratedCode": false,
    "windows": {
      "namespace": "ExpoDesktopStubsCodegen",
      "outputDirectory": "windows/ExpoDesktopStubs/codegen",
      "separateDataTypes": true
    }
  }
}
